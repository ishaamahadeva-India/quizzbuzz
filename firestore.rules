rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    // Helper: super-admin email OR users/{uid}.isAdmin == true (for IPL / ops admins)
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@fantasy.com' ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
        )
      );
    }

    match /users/{userId} {
      allow read: if isAuthenticated() &&
                    (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated();
      allow update: if isAdmin() ||
                      (isAuthenticated() && request.auth.uid == userId);
      match /milestone-progress/{progressId} {
        allow read: if isAuthenticated() &&
                      (request.auth.uid == userId || isAdmin());
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update: if isAuthenticated() && request.auth.uid == userId;
        allow delete: if isAdmin();
      }
      match /game-plays/{playId} {
        allow read: if isAuthenticated() &&
                      (request.auth.uid == userId || isAdmin());
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update: if isAuthenticated() && request.auth.uid == userId;
        allow delete: if isAdmin();
      }
    }

    match /reward-milestones/{milestoneId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /vouchers/{voucherId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /voucher-redemptions/{redemptionId} {
      allow read: if isAuthenticated() &&
                     (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /gossips/{gossipId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /cricketers/{cricketerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /movies/{movieId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /stars/{starId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /fantasy-campaigns/{campaignId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      match /events/{eventId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
        match /predictions/{predictionId} {
          allow read: if isAuthenticated();
          allow create: if isAuthenticated() &&
                         request.resource.data.userId == request.auth.uid;
          allow update: if isAuthenticated() &&
                         resource.data.userId == request.auth.uid &&
                         request.resource.data.userId == request.auth.uid;
          allow delete: if isAuthenticated() &&
                         resource.data.userId == request.auth.uid;
        }
      }
      match /participations/{participationId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() &&
                        resource.data.userId == request.auth.uid;
      }
    }

    // Fantasy Matches: public read so list works before auth / without login; write admin only
    match /fantasy_matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
      match /events/{eventId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Cricket Tournaments: public read so list works without login; write admin only
    match /cricket-tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isAdmin();
      match /events/{eventId} {
        allow read: if true;
        allow write: if isAdmin();
      }
      match /participations/{participationId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() &&
                        resource.data.userId == request.auth.uid;
      }
    }

    match /user-predictions/{predictionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
    }
    match /tournament-entries/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
    }
    match /tournament-predictions/{predictionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
    }
    match /campaign-entries/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
    }
    match /participations/{participationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
    }

    match /team-eras/{eraId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /performances/{performanceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /star-eras/{eraId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid &&
                      request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /advertisements/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /coupons/{couponId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }
    match /coupon-redemptions/{redemptionId} {
      allow read: if isAdmin();
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /image-advertisements/{adId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /image-ad-views/{viewId} {
      allow read: if isAuthenticated() &&
                     (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
    match /image-ad-sponsors/{sponsorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /quiz_attempts/{attemptId} {
      allow create: if isAuthenticated() &&
                     request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
    match /brand_events/{eventId} {
      allow create: if true;
      allow read: if isAdmin() ||
                    (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
    match /coupon_redemptions/{redemptionId} {
      allow create: if isAuthenticated() &&
                     request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() ||
                    (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
    match /sessions/{sessionId} {
      allow create: if true;
      allow read: if isAdmin() ||
                    (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
    match /analytics_events/{eventId} {
      allow create: if true;
      allow read: if isAdmin() ||
                    (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
    match /point_transactions/{transactionId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // IPL Fantasy Engine
    match /ipl_players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ipl_matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /player_match_stats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /player_selection_stats/{statId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }
    // IPL user picks: public read so leaderboard works without login; write only own or admin
    match /ipl_user_picks/{pickId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
